# API de Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Base de Datos
DATABASE_URL=sqlite+aiosqlite:///./data/agency.db

# Configuración FastAPI
CORS_ORIGINS=http://localhost:5173

# Configuración Google Sheets
GOOGLE_SHEETS_ID=tu-sheet-id-aqui
GOOGLE_CREDENTIALS_PATH=./credentials/google-credentials.json

# Configuración Gmail para notificaciones
GMAIL_SENDER_EMAIL=tu-email@gmail.com
GMAIL_APP_PASSWORD=tu-app-password-aqui
GMAIL_RECIPIENT_EMAIL=email-destino@gmail.com
GMAIL_ENABLED=false
